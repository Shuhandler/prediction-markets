# Copy to .env and fill in.  chmod 600 .env — never commit it.

# ── Kalshi (required for paper + live: WS auth is read-only) ──
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=keys/kalshi_private.pem

# ── Polymarket (live mode only) ──
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_PRIVATE_KEY_PATH=keys/poly_private.txt

# ── Strategy ──
MIN_PROFIT_MARGIN=0.05
STARTING_CAPITAL=1000.00
POSITION_SIZE=50.00
KALSHI_FEE_RATE=0.07
POLY_FEE_RATE=0.25          # sports quadratic; crypto: 0.0175 with exponent 1
POLY_FEE_EXPONENT=2

# ── Risk ──
DAILY_LOSS_LIMIT=100.00
MAX_TOTAL_EXPOSURE=500.00
MAX_CONCURRENT_POSITIONS=10
MAX_SPREAD_THRESHOLD=0.20
MAX_ORDERS_PER_MINUTE=10

# ── Operations (Phase 6) ──
# STATE_DB_FILE=data/state.db
# HEALTH_HOST=127.0.0.1
# HEALTH_PORT=8080          # 0 disables
# DRAIN_TIMEOUT_SECONDS=20
# MIN_PLATFORM_BALANCE=50.00
# BALANCE_CHECK_INTERVAL=300
# LOG_FORMAT=text           # or json
# LOG_FILE=                 # e.g. data/arb_bot.log (10MB x 5 rotation)

# ── Notifications ──
# DISCORD_WEBHOOK_URL=
